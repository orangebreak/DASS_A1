# MongoDB Connection String
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/felicity?retryWrites=true&w=majority

# JWT Secret for authentication tokens
JWT_SECRET=your_secret_key_here

# reCAPTCHA Secret Key (get from https://www.google.com/recaptcha/admin)
# This is the private key used to verify captcha tokens on the backend
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Note: If RECAPTCHA_SECRET_KEY is not set, captcha verification will be skipped.
# To enable proper reCAPTCHA validation, get your keys from Google reCAPTCHA admin.
